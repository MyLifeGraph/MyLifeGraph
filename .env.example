# Shared local defaults. Copy this file to `.env` for local development.
APP_ENV=development

# Keep true for the reliable local guest/demo path.
USE_MOCK_DATA=true

# Leave empty for guest/mock mode. Fill both values to enable Supabase Auth.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional FastAPI AI service. Not required for the default mock preview.
AI_SERVICE_BASE_URL=http://localhost:8000

# Leave empty for the fail-closed build default: enabled in debug/profile
# development, hidden in release or APP_ENV=production. Set exact `true` only
# after explicitly accepting the surface/provider boundary for that build.
COACH_SURFACE_ENABLED=
