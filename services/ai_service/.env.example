APP_ENV=development
API_PREFIX=/v1
ALLOWED_ORIGINS=http://127.0.0.1:7357,http://localhost:7357

# Required for authenticated persistence workflows.
SUPABASE_URL=

# Backend-only secret. Never expose this to Flutter or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_TIMEOUT_SECONDS=10

# Backend-only token used by the scheduled daily preparation endpoint.
SCHEDULED_REFRESH_TOKEN=
