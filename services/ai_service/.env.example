APP_ENV=development
API_PREFIX=/v1
ALLOWED_ORIGINS=http://127.0.0.1:7357,http://localhost:7357

# Required for authenticated persistence workflows.
SUPABASE_URL=

# Backend-only secret. Never expose this to Flutter or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_TIMEOUT_SECONDS=10

# Backend-only token used by the scheduled daily preparation endpoint.
SCHEDULED_REFRESH_TOKEN=

# Coach is off by default. The fake provider is deterministic and intended only
# for automated development/test journeys.
COACH_PROVIDER=disabled
COACH_FAKE_PROVIDER_ENABLED=false

# Development-only subscription-backed adapter. Enabling it requires an
# already authenticated local Codex CLI; OAuth state stays outside this repo.
LOCAL_CODEX_ENABLED=false
LOCAL_CODEX_BIN=codex
LOCAL_CODEX_MODEL=gpt-5.5
LOCAL_CODEX_TIMEOUT_SECONDS=45
LOCAL_CODEX_MAX_REQUESTS_PER_USER_PER_DAY=20
LOCAL_CODEX_GLOBAL_CONCURRENCY=2
